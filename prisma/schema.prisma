datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  location  String?
  summary   String?
  heroImage String?
  content   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  units     Unit[]

  @@index([title])
}

model Unit {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  unitType  String
  area      Float?
  building  String?
  floor     String?
  view      String?
  legal     String?
  price     Float?
  furniture String?
  content   String?
  images    String[]
  status    String   @default("Available")
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([title])
  @@index([projectId])
  @@index([unitType])
  @@index([price])
  @@index([status])
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  coverImage  String?
  content     String?
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lead {
  id        String   @id @default(cuid())
  name      String?
  phone     String
  email     String?
  message   String?
  page      String?
  createdAt DateTime @default(now())
}
