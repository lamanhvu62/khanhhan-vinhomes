datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  type        String   @default("Apartment") // Căn hộ, Nhà phố, Shophouse...
  location    String?
  summary     String?
  heroImage   String?  // Ảnh đại diện chính
  images      String[] // Danh sách ảnh phối cảnh dự án
  priceMin    Float?   // Giá thấp nhất để hiển thị "Giá từ..."
  content     String?  @db.Text
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  units       Unit[]

  @@index([title])
  @@index([type])
}

model Unit {
  id        String   @id @default(cuid())
  title     String   // Ví dụ: Bcons City - Tháp Green Topaz - Căn A1
  slug      String   @unique
  unitType  String   // 1PN, 2PN, 3PN
  area      Float?
  building  String?  // Tên tháp (ví dụ: Diamond, Solis...)
  floor     String?
  view      String?  // View hồ bơi, view Landmark 81...
  legal     String?  @default("Hợp đồng mua bán")
  price     Float?
  furniture String?  // Giao thô, hoàn thiện cơ bản...
  content   String?  @db.Text
  images    String[]
  status    String   @default("Available") // Available, Booked, Sold
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([title])
  @@index([projectId])
  @@index([unitType])
  @@index([price])
  @@index([status])
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  coverImage  String?
  content     String?  @db.Text
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([title])
}

model Lead {
  id        String   @id @default(cuid())
  name      String?
  phone     String
  email     String?
  message   String?
  page      String?  // Khách để lại thông tin từ trang nào (Dự án A hay Bài viết B)
  createdAt DateTime @default(now())

  @@index([phone])
}